# ── Go ────────────────────────────────────────────────────────────────────────
# CLI binary produced by `go build` at the repo root.
/pero

# Compiled test binaries.
*.test

# Delve / debugger artifacts.
__debug_bin*

# ── Wails GUI ─────────────────────────────────────────────────────────────────
# Compiled .app bundle.  Install via `cp -R gui/build/bin/pero.app /Applications/`.
gui/build/bin/

# Vite-compiled frontend bundle (regenerated by `wails build` or `npm run build`).
gui/frontend/dist/

# npm dependencies (restored by `npm install` or automatically by `wails build/dev`).
gui/frontend/node_modules/

# Wails-generated checksum — not meaningful outside the local build cache.
gui/frontend/package.json.md5
